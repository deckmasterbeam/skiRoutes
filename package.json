{
  "name": "ski-routes-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "lint:frontend": "npm --prefix frontend run lint",
    "preview:frontend": "npm --prefix frontend run preview",
    "dev:backend": "python backend/app.py",
    "test:backend": "python -m pytest backend/tests",
    "dev": "npm run dev:frontend",
    "deploy:backend:preview": "vercel deploy backend -y --no-wait",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,css,md}": "prettier --write"
  }
}
